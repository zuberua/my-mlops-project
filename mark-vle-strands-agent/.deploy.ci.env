# Mark Vle Agent - CI/CD Deployment Configuration
# Used by GitHub Actions workflow

# AWS Configuration (credentials from GitHub Actions)
# AWS_PROFILE is intentionally not set - GitHub Actions uses IAM role
AWS_REGION=us-west-2

# S3 Vector Bucket Configuration
BUCKET_NAME=markvie-vectors
ENVIRONMENT=production

# CloudFormation Stack Name
STACK_NAME=mark-vle-vector-bucket

# Non-Interactive Mode
NON_INTERACTIVE=true
CI=true
