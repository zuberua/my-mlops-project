# Mark Vle Agent - Deployment Configuration
# Copy this file to .deploy.env and customize for your environment

# AWS Configuration
# For local development: Set AWS_PROFILE to your AWS CLI profile
# For CI/CD: Leave AWS_PROFILE empty (uses IAM role)
AWS_PROFILE=zuberua-Admin
AWS_REGION=us-west-2

# S3 Vector Bucket Configuration
BUCKET_NAME=markvie-vectors
ENVIRONMENT=production

# CloudFormation Stack Name
STACK_NAME=mark-vle-vector-bucket

# ECR Configuration (for CI/CD Docker builds)
ECR_REPOSITORY=cdk-hnb659fds-container-assets-138720056246-us-west-2
IMAGE_TAG=latest

# Non-Interactive Mode
# Set to true for CI/CD, false for local development
NON_INTERACTIVE=false
CI=false
