# LiteLLM Proxy Configuration
LITELLM_API_KEY=your-api-key-here
LITELLM_PROXY_URL=https://your-litellm-proxy.com
LITELLM_MODEL=litellm_proxy/bedrock-claude-sonnet-4.5
LITELLM_API_KEY_PROVIDER=bedrock

# AgentCore Identity (optional - for authentication)
AGENT_IDENTITY_NAME=mark-vle-identity
AGENT_IDENTITY_SCOPES=read,write

# AWS Configuration
AWS_REGION=us-west-2
S3_BUCKET_NAME=mark-vie-s3-rag

# Embedding Model
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# Agent Configuration
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=2000

# RAG Configuration
RAG_MAX_RESULTS=3
RAG_SIMILARITY_THRESHOLD=0.5
